# ──────────────────────────────────────────────────────────────────────────
#  .env.example  —  Copy this to .env and fill in your real credentials
# ──────────────────────────────────────────────────────────────────────────

# Your Capgemini Generative Engine API key
CAPGEMINI_API_KEY=your_api_key_here

# Full REST endpoint for Amazon Nova Lite via Capgemini's API gateway
# Example format: https://your-capgemini-gateway.com/v1/messages
CAPGEMINI_API_ENDPOINT=https://your-capgemini-endpoint-url-here/v1/messages
